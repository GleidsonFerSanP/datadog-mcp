{
    "name": "datadog-observability",
    "displayName": "Datadog Observability for GitHub Copilot",
    "description": "AI-powered Datadog observability tools — Logs, Metrics, Monitors, Dashboards, APM, Incidents and more directly from GitHub Copilot Chat",
    "version": "1.0.0",
    "publisher": "GleidsonFerSanP",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "AI",
        "Other",
        "Visualization"
    ],
    "keywords": [
        "datadog",
        "observability",
        "monitoring",
        "logs",
        "metrics",
        "apm",
        "traces",
        "dashboards",
        "incidents",
        "mcp",
        "copilot",
        "model context protocol"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "mcpServerDefinitionProviders": [
            {
                "id": "datadog-observability",
                "label": "Datadog Observability"
            }
        ],
        "chatInstructions": [
            {
                "name": "DatadogObservabilityGuidelines",
                "description": "Guidelines for using Datadog observability tools through MCP",
                "path": "resources/instructions/datadog.instructions.md"
            }
        ],
        "commands": [
            {
                "command": "datadogObservability.configure",
                "title": "Configure Datadog Credentials"
            },
            {
                "command": "datadogObservability.testConnection",
                "title": "Test Datadog Connection"
            },
            {
                "command": "datadogObservability.restart",
                "title": "Restart Datadog MCP Server"
            },
            {
                "command": "datadogObservability.viewDocs",
                "title": "Open Datadog MCP Documentation"
            }
        ],
        "configuration": {
            "title": "Datadog Observability",
            "properties": {
                "datadogObservability.site": {
                    "type": "string",
                    "enum": [
                        "datadoghq.com",
                        "us3.datadoghq.com",
                        "us5.datadoghq.com",
                        "datadoghq.eu",
                        "ap1.datadoghq.com",
                        "ddog-gov.com"
                    ],
                    "default": "datadoghq.com",
                    "description": "Datadog site to connect to"
                },
                "datadogObservability.defaultTimeRange": {
                    "type": "string",
                    "enum": [
                        "15m",
                        "1h",
                        "4h",
                        "1d",
                        "7d"
                    ],
                    "default": "1h",
                    "description": "Default time range for queries"
                },
                "datadogObservability.logLevel": {
                    "type": "string",
                    "enum": [
                        "error",
                        "warn",
                        "info",
                        "debug"
                    ],
                    "default": "info",
                    "description": "Log level for the extension"
                },
                "datadogObservability.autoStart": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically start the Datadog MCP server on extension activation"
                },
                "datadogObservability.maxResults": {
                    "type": "number",
                    "default": 50,
                    "description": "Maximum number of results returned by queries"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile && npm run copy-server",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "copy-server": "cd .. && npm run build && npm run copy-to-extension",
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@vscode/vsce": "^2.22.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/GleidsonFerSanP/datadog-mcp.git"
    },
    "license": "MIT"
}